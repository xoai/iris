{
  "name": "@irisrun/sdk",
  "version": "0.3.0",
  "type": "module",
  "description": "Iris adapter SDK — one dependency to build a store, channel, or provider adapter. Curated re-exports of the three port type-sets, the three importable conformance suites, and the forkless-loader contracts (openStore / openModelProvider / openChannel). Pair it with `iris adapter init`.",
  "exports": {
    ".": {
      "iris-src": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@irisrun/core": "^0.3.0",
    "@irisrun/host": "^0.3.0",
    "@irisrun/channel-core": "^0.3.0",
    "@irisrun/channel-rest": "^0.3.0",
    "@irisrun/store-conformance": "^0.3.0",
    "@irisrun/channel-conformance": "^0.3.0",
    "@irisrun/provider-conformance": "^0.3.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xoai/iris.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/xoai/iris#readme",
  "files": [
    "dist"
  ]
}
