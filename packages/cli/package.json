{
  "name": "iris",
  "version": "0.1.0",
  "type": "module",
  "description": "Iris CLI — iris init/build/inspect/verify/push/pull/run. Command functions over @iris/agent (so they are unit-testable with injected deps) + a zero-dep argv dispatcher. push/pull operate on a local OCI layout (real registry = manual); run drives the existing host adapters.",
  "exports": {
    ".": {
      "iris-src": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "iris": "./dist/cli-main.js"
  },
  "dependencies": {
    "@iris/core": "^0.1.0",
    "@iris/tools": "^0.1.0",
    "@iris/agent": "^0.1.0",
    "@iris/host": "^0.1.0",
    "@iris/channel-rest": "^0.1.0",
    "@iris/channel-web": "^0.1.0",
    "@iris/store-do": "^0.1.0",
    "@iris/store-sqlite": "^0.1.0",
    "@iris/provider-anthropic": "^0.1.0",
    "@iris/auth": "^0.1.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xoai/iris.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/xoai/iris#readme",
  "files": [
    "dist"
  ]
}
