{
  "name": "iris-workspace",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Iris — a portable durability runtime for stateful agents.",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "packages/*",
    "tests"
  ],
  "scripts": {
    "test": "NODE_OPTIONS=--conditions=iris-src node --test 'tests/**/*.test.ts'",
    "demo:cross-host": "NODE_OPTIONS=--conditions=iris-src node tests/manual/cross-host-journal-demo.ts",
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
    "build": "node scripts/build.mjs",
    "version:set": "node scripts/version.mjs",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry-run"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
